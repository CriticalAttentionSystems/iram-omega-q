analysis/reset_rerun_paper4_main_clean.sh
analysis/runPaper4Adds.sh
analysis/runPaper4Diagnostics.sh
analysis/runPaper4OptionBFocusedReplicates.sh
analysis/runPaper4OptionBFocusedReplicatesRemakePlots.sh
analysis/runPaper4SimulationsFull.sh
cpFigsAdaptBeh.sh

