# --- Analysis generated results ---
analysis/results/

# Ignore generated paper-3/4 run outputs, but keep the reproducibility
# config/manifests under config/ (source inputs the analysis scripts need).
# Ignore the directory *contents* (/*), not the directory itself, so the
# config/ negation below can re-include: git cannot re-include a path whose
# parent directory has been excluded outright.
analysis/paper3/*
!analysis/paper3/config/
analysis/paper4/*
!analysis/paper4/config/

analysis/results/paper3/
analysis/results/paper4/
analysis/results/paper4_focused_n10/
analysis/results/paper4_optionB_focus_n10/

# --- Temporary paper-4 listing/check files ---
list_paper4
list_paper4_focus

# --- Local simulation output/work dirs ---
sim/

